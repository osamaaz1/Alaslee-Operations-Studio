{
  "name": "alaslee-operations-studio",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Alaslee unified Arabic operations studio for analytics, product imagery, campaigns, and store readiness.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "node --watch src/server.js",
    "dev:client": "vite --host 0.0.0.0 --config client/vite.config.js",
    "build": "vite build --config client/vite.config.js",
    "preview": "vite preview --config client/vite.config.js",
    "crm:db:up": "docker compose --env-file .env -f compose.crm.yml up -d",
    "crm:db:down": "docker compose --env-file .env -f compose.crm.yml down",
    "crm:migrate": "node src/infra/crm/cli.js migrate",
    "crm:rotate-encryption": "node src/infra/crm/cli.js rotate-encryption",
    "crm:rollback": "node src/infra/crm/cli.js rollback",
    "crm:status": "node src/infra/crm/cli.js status",
    "import:v1": "node scripts/import-v1.js",
    "production:preflight": "node scripts/production-preflight.js",
    "production:smoke": "node scripts/production-http-smoke.js",
    "production:test": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/test-production.ps1",
    "production:backup": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/backup-production.ps1",
    "production:restore:verify": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/verify-backup-restore.ps1",
    "check": "node scripts/check-syntax.js && npm audit --audit-level=high && npm run build && npm test",
    "test": "node --test",
    "test:api": "node --test test/*.api.test.js",
    "test:ui": "node --test test/*.ui.test.js",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@google/genai": "^2.10.0",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.5.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "file-type": "^21.1.1",
    "helmet": "^8.1.0",
    "libphonenumber-js": "^1.13.8",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.2",
    "openai": "^6.15.0",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5",
    "vite": "^7.1.12",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
