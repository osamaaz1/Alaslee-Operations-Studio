PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
# Local Vite frontend permitted to send write requests through its proxy.
LOCAL_DEV_CLIENT_ORIGIN=http://localhost:5173

# Select one: gemini, gpt, or free-test
AI_PROVIDER=gemini

# Google AI Studio / Gemini API
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-image

# OpenAI Images API
OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_PRICE_LABEL_MODEL=gpt-image-2
OPENAI_REQUEST_TIMEOUT_MS=180000
OPENAI_IMAGE_REQUEST_SIZE=auto
OPENAI_IMAGE_QUALITY=medium

# Local persistence
DATABASE_PATH=./data/products.sqlite
ORIGINALEYE_DATA_ROOT=./OriginalEye-Data-Analysis
UPLOADS_DIR=./uploads
ALLOWED_IMPORT_ROOTS=.

# Local CRM PostgreSQL (use strong local values; never commit .env)
CRM_POSTGRES_DB=alaslee_crm
CRM_POSTGRES_USER=alaslee_crm
CRM_POSTGRES_PASSWORD=123456
CRM_POSTGRES_PORT=5433
CRM_DATABASE_URL=postgresql://alaslee_crm:CHANGE_ME@127.0.0.1:5433/alaslee_crm
CRM_DATA_ENCRYPTION_KEY=123456
# Use only during a one-time encryption-key rotation, then remove it.
CRM_DATA_ENCRYPTION_PREVIOUS_KEYS=
CRM_STAFF_PIN=123456
CRM_SUPERUSER_PIN=123456
# Leave empty for the safe default: disabled in development, enabled when NODE_ENV=production.
CRM_LOGIN_RATE_LIMIT_DISABLED=
CRM_SESSION_HOURS=8
CRM_PRICE_FLOOR_PERCENT=50

# Optional Supabase: private Feedback reports and remote PostgreSQL CRM.
# Use a server-only Secret key (preferred) or legacy service-role key; never expose it in the browser.
SUPABASE_URL=
SUPABASE_SECRET_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_FEEDBACK_BUCKET=feedback-attachments
SUPABASE_FEEDBACK_MAX_IMAGE_MB=6
SUPABASE_FEEDBACK_RATE_LIMIT_WINDOW_MS=900000
SUPABASE_FEEDBACK_RATE_LIMIT_MAX=10
# To move CRM to Supabase PostgreSQL, replace CRM_DATABASE_URL with the Supabase connection string
# (or leave CRM_DATABASE_URL empty and set this fallback). Run `npm run crm:migrate` after cutover.
SUPABASE_DATABASE_URL=

# Read-only Daftra synchronization
DAFTRA_SUBDOMAIN=
# An API key is sufficient for a direct Daftra account connection.
DAFTRA_API_KEY=
# Optional: use only when Daftra provides an OAuth/Bearer token for your app.
DAFTRA_ACCESS_TOKEN=
DAFTRA_SYNC_MINUTES=60

# Upload and output controls
MAX_IMAGE_MB=20
OUTPUT_IMAGE_SIZE=2048

# Optional local API protection
ADMIN_API_KEY=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# Optional Instagram branding assets
BRAND_BACKGROUND_PATH=
BRAND_LOGO_PATH=
BRAND_FOOTER_PATH=
BRAND_PRICE_LABEL_REFERENCE_PATH=
BRAND_LOGO_CORNER=top-right

# Optional Salla status/integration
CRM_SALLA_CLIENT_ID=
CRM_SALLA_REDIRECT_URI=
CRM_SALLA_WEBHOOK_SECRET=
CRM_SALLA_ACCESS_TOKEN=
CRM_SALLA_API_BASE_URL=https://api.salla.dev/admin/v2
